# ─────────────────────────────────────────────────────────────────────────────
# Scan & Go — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Frontend) ───────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# ── Razorpay (Frontend) ───────────────────────────────────────────────────────
# Only the Key ID goes here — NEVER put the secret in frontend env vars
# Found in: Razorpay Dashboard → Settings → API Keys
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id

# ── Supabase (Backend / Edge Functions) ──────────────────────────────────────
# Used by FastAPI service and Supabase Edge Functions
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Razorpay (Backend / Edge Functions) ──────────────────────────────────────
# Both key and secret are used server-side only
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── CORS (FastAPI) ────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for development
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
